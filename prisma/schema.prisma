generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url przeniesiony do prisma.config.ts w Prisma 7
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  WAITING
  DONE
  CANCELED
}

enum SLATYPE {
  STANDARD
  EXPRESS
  VIP
  WARRANTY
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum TicketEventType {
  CREATED
  STATUS
  NOTE
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices Device[]
  tickets  Ticket[]
}

model Device {
  id         String   @id @default(cuid())
  customerId String
  name       String
  serial     String?
  model      String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  tickets  Ticket[]
}

model Ticket {
  id         String  @id @default(cuid())
  number     String  @unique
  customerId String
  deviceId   String?

  title       String
  description String?

  status   TicketStatus   @default(NEW)
  priority TicketPriority @default(NORMAL)
  slaType  SLATYPE        @default(STANDARD)

  physicalCondition String?
  accessories       String[] // Postgres array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  device   Device?  @relation(fields: [deviceId], references: [id])

  events TicketEvent[]
  partReservations PartReservation[]

  @@index([customerId])
  @@index([deviceId])
  @@index([status])
  @@index([priority])
  @@index([slaType])
  @@index([createdAt])
}

model TicketEvent {
  id        String         @id @default(cuid())
  ticketId  String
  type      TicketEventType
  message   String
  author    String?
  createdAt DateTime       @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model Part {
  id           String   @id @default(cuid())
  sku          String   @unique
  name         String
  quantity     Int      @default(0)
  minQuantity  Int      @default(0)
  price        Decimal  @db.Decimal(10, 2)
  reserved     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reservations PartReservation[]

  @@index([sku])
  @@index([quantity])
  @@index([minQuantity])
}

model PartReservation {
  id        String   @id @default(cuid())
  partId    String
  ticketId  String
  quantity  Int
  createdAt DateTime @default(now())

  part   Part   @relation(fields: [partId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([partId])
  @@index([ticketId])
  @@index([createdAt])
}
