generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url przeniesiony do prisma.config.ts w Prisma 7
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  WAITING
  DONE
  CANCELED
}

enum SLATYPE {
  STANDARD
  EXPRESS
  VIP
  WARRANTY
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum TicketEventType {
  CREATED
  STATUS
  NOTE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum QuotePublicAccess {
  PUBLIC
  VIEW_ONLY
  HIDDEN
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices Device[]
  tickets Ticket[]
  quotes  Quote[]
}

model Device {
  id         String   @id @default(cuid())
  customerId String
  name       String
  serial     String?
  model      String?
  notes      String?
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  tickets  Ticket[]
  quotes   Quote[]
}

model Ticket {
  id         String  @id @default(cuid())
  number     String  @unique
  customerId String
  deviceId   String?

  title       String
  description String?

  status         TicketStatus    @default(NEW)
  priority       TicketPriority  @default(NORMAL)
  slaType        SLATYPE         @default(STANDARD)
  repairProtocol RepairProtocol?

  physicalCondition String?
  accessories       String[] // Postgres array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  device   Device?  @relation(fields: [deviceId], references: [id])

  events           TicketEvent[]
  partReservations PartReservation[]
  quotes           Quote[]

  @@index([customerId])
  @@index([deviceId])
  @@index([status])
  @@index([priority])
  @@index([slaType])
  @@index([createdAt])
}

model TicketEvent {
  id        String          @id @default(cuid())
  ticketId  String
  type      TicketEventType
  message   String
  author    String?
  createdAt DateTime        @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model Part {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  quantity    Int      @default(0)
  minQuantity Int      @default(0)
  price       Decimal  @db.Decimal(10, 2)
  reserved    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reservations PartReservation[]
  quoteItems   QuoteItem[]

  @@index([sku])
  @@index([quantity])
  @@index([minQuantity])
}

model PartReservation {
  id        String   @id @default(cuid())
  partId    String
  ticketId  String
  quantity  Int
  createdAt DateTime @default(now())

  part   Part   @relation(fields: [partId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([partId])
  @@index([ticketId])
  @@index([createdAt])
}

model Quote {
  id         String      @id @default(cuid())
  number     String      @unique
  ticketId   String
  customerId String
  deviceId   String?
  status     QuoteStatus @default(DRAFT)
  publicAccess QuotePublicAccess @default(HIDDEN)
  laborHours Decimal     @default(0)
  laborRate  Decimal     @default(0)
  vatRate    Decimal     @default(23)
  notes      String?
  totalNet   Decimal     @default(0)
  totalVat   Decimal     @default(0)
  totalGross Decimal     @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  customer Customer    @relation(fields: [customerId], references: [id])
  ticket   Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  device   Device?     @relation(fields: [deviceId], references: [id])
  items    QuoteItem[]

  @@index([status])
  @@index([customerId])
  @@index([ticketId])
  @@index([createdAt])
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  partId      String?
  description String
  quantity    Int
  unitPrice   Decimal
  total       Decimal

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  part  Part? @relation(fields: [partId], references: [id])

  @@index([quoteId])
  @@index([partId])
}

model RepairProtocol {
  id String @id @default(cuid())

  ticketId String @unique
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  performedWork String
  repairCost    Decimal @db.Decimal(10, 2)
  servicePerson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
